CBR_BASE_URL=https://www.cbr.ru
CBR_FULL_LIST_URL=https://www.cbr.ru/banking_sector/credit/FullCoList/

BROKER_URL=redis://redis:6379/0
RESULT_BACKEND=redis://redis:6379/1

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cbr_reports
DB_POOL_MAX_SIZE=30

DATA_DIR=/app/data

LOG_LEVEL=INFO

HTTP_TIMEOUT_SECONDS=30
HTTP_CONNECT_TIMEOUT_SECONDS=10
HTTP_READ_TIMEOUT_SECONDS=30

HTTP_MAX_CONNECTIONS=150
HTTP_MAX_KEEPALIVE_CONNECTIONS=50
HTTP_MAX_CONCURRENCY=30
HTTP_PER_HOST_CONCURRENCY=15
HTTP_RPS_LIMIT=12

FETCH_BANK_BATCH_SIZE=25
FETCH_REPORT_BATCH_SIZE=30
AGGREGATE_BANK_BATCH_SIZE=400

CELERY_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_RESULT_EXPIRES_SECONDS=3600

BANK_LIMIT=0
ONLY_OGRN=

USER_AGENT=Mozilla/5.0 (compatible; CBRReportsBot/1.0; +https://www.cbr.ru)